{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node 'F:\\Game\\jump-once\\.codex\\hooks\\session_start.js'",
            "timeout": 15,
            "statusMessage": "Jump Once: loading reboot lifecycle + handoff"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node tools/sdlc/gate.js --hook stop",
            "timeout": 20,
